# ─────────────────────────────────────────────
# Vercel Postgres — copia estas variables desde:
# Vercel Dashboard → Storage → tu DB → .env Local
# ─────────────────────────────────────────────

# Conexión pooled via PgBouncer → runtime serverless (Next.js API routes)
POSTGRES_PRISMA_URL="postgres://USER:PASSWORD@HOST/DB?pgbouncer=true&connect_timeout=15"

# Conexión directa → migraciones (prisma migrate dev / deploy)
POSTGRES_URL_NON_POOLING="postgres://USER:PASSWORD@HOST/DB"
